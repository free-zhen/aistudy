# ===========================================================
#  全局 API Key 配置模板
#  用法：把本文件复制为项目根目录的 .env，然后填入真实值
#  PowerShell:  Copy-Item config/.env.example .env
#  Mac/Linux :  cp config/.env.example .env
# ===========================================================

# --- DeepSeek（本课程默认使用） ---
# 注册并获取 Key：https://platform.deepseek.com/  （详见第 00 章）
DEEPSEEK_API_KEY=sk-在这里填入你的真实密钥
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# --- 可选：如果以后想换成 OpenAI / 其它兼容接口，按需填写 ---
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# --- 应用配置（后面章节会用到） ---
# 后端服务端口
APP_PORT=8000
